# Supabase — required for Phase 1 (web + realtime)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Server-only: never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Colyseus (realtime)
REALTIME_PORT=2567
NEXT_PUBLIC_REALTIME_URL=ws://localhost:2567

# Stripe — Phase 2, do not set yet
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Sentry — optional, not wired at scaffold time
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
